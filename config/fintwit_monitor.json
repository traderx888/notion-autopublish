    {"handle": "profitsplusid",  "name": "ProfitsPlus",            "tier": 3, "tags": ["commodities"]}
  ],

  "min_content_score": 15,

  "tier_scores": {
    "1": 100,
    "2": 85,
    "3": 75,
    "4": 60
  },

  "content_signals": {
    "high_conviction": {
      "patterns": ["extremely", "absurdly", "10x", "100x", "asymmetric", "mispriced", "generational", "once in a lifetime", "biggest opportunity", "no-brainer"],
      "weight": 15
    },
    "direction": {
      "patterns": [
        "(?:go|going|went|been|am|i'm|we're|we are|still|remain|stay|get)\\s+long\\b",
        "\\blong\\s+(?:\\$[a-z]|gold|silver|crude|oil|bonds?|treasur|equit|stock|call|put|futures?|position|exposure)",
        "(?:go|going|went|been|am|i'm|we're|we are|still|remain|stay|get)\\s+short\\b",
        "\\bshort\\s+(?:\\$[a-z]|gold|silver|crude|oil|bonds?|treasur|equit|stock|call|put|futures?|position|squeeze)",
        "\\bshort(?:ing|ed)\\b",
        "\\bbuy\\b", "\\bsell\\b", "undervalued", "overvalued",
        "bullish", "bearish", "oversold", "overbought",
        "headed to", "going to \\$", "inevitable", "rally", "crash", "moon", "dump"
      ],
      "weight": 20
    },
    "position_disclosure": {
      "patterns": ["we bought", "we sold", "added to", "our position", "our largest", "increased exposure", "trimmed", "exited"],
      "weight": 10
    },
    "price_target": {
      "patterns": ["fair value", "target \\$", "worth \\$", "price target", "intrinsic value"],
      "weight": 15
    },
    "crisis_language": {
      "patterns": ["collapse", "squeeze", "black swan", "systemic", "contagion", "margin call", "liquidation", "bankrupt"],
      "weight": 10
    },
    "noise_penalty": {
      "patterns": ["subscribe", "newsletter", "podcast episode", "new video", "check out my", "RT if you", "giveaway"],
      "weight": -20
    },
    "social_noise_penalty": {
      "patterns": [
        "had the pleasure", "great meeting", "great to meet", "pleasure to meet",
        "catching up with", "dinner with", "lunch with", "coffee with", "drinks with",
        "speaking at", "panel at", "event at", "keynote at",
        "marriott|hilton|hyatt|ritz|four seasons|shangri.la|peninsula|mandarin oriental",
        "thank you for having me", "enjoyed the conversation",
        "honored to speak", "honour to speak",
        "excited to announce.*(?:joined|joining|new role|partner)"
      ],
      "weight": -25
    }
  },

  "ticker_patterns": {
    "cashtag_regex": "\\$([A-Z]{1,5})\\b",
    "known_tickers": ["NVDA", "AAPL", "TSLA", "MSFT", "AMZN", "GOOG", "META", "NFLX", "AMD", "INTC",
                       "SPY", "QQQ", "IWM", "DIA", "XLF", "XLE", "XLK",
                       "FNMA", "FMCC", "GME", "AMC",
                       "GLD", "SLV", "USO", "UNG", "COPX",
                       "TLT", "TMV", "TBT", "TMF",
                       "VIX", "UVXY", "VXX", "SVXY",
                       "BTC", "ETH", "SOL", "XRP"],
    "company_map": {
      "fannie mae": "FNMA", "freddie mac": "FMCC",
      "tesla": "TSLA", "nvidia": "NVDA", "apple": "AAPL",
      "microsoft": "MSFT", "amazon": "AMZN", "google": "GOOG",
      "meta": "META", "netflix": "NFLX",
      "bitcoin": "BTC", "ethereum": "ETH", "solana": "SOL",
      "gold": "GLD", "silver": "SLV", "crude": "USO", "oil": "USO",
      "natural gas": "UNG", "copper": "COPX"
    },
    "asset_classes": {
      "us_equity": ["NVDA", "AAPL", "TSLA", "MSFT", "AMZN", "GOOG", "META", "NFLX", "AMD", "INTC", "FNMA", "FMCC", "GME", "AMC"],
      "etf": ["SPY", "QQQ", "IWM", "DIA", "XLF", "XLE", "XLK"],
      "commodity": ["GLD", "SLV", "USO", "UNG", "COPX"],
      "rates": ["TLT", "TMV", "TBT", "TMF"],
      "volatility": ["VIX", "UVXY", "VXX", "SVXY"],
      "crypto": ["BTC", "ETH", "SOL", "XRP"]
    }
  }
}
