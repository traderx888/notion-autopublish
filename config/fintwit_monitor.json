{
  "polling_interval_minutes": 120,
  "score_threshold": 60,
  "max_alerts_per_day": 10,
  "tweets_per_account": 10,
  "telegram_bot_token_env": "TELEGRAM_BOT_TOKEN_OPS",
  "telegram_chat_id_env": "TELEGRAM_CHAT_ID_OPS",
  "state_file": "scraped_data/twitter/fintwit_state.json",
  "log_file": "outputs/ops/fintwit_monitor.log",

  "scoring_weights": {
    "account": 0.30,
    "content": 0.40,
    "engagement": 0.20,
    "recency": 0.10
  },

